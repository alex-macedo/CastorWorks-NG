    "validate:json": "node scripts/validate-json.js",
    "i18n:scan": "i18next-scanner --config i18next-scanner.config.cjs",
    "i18n:check": "node scripts/check-translations.cjs",
    "i18n:report": "node scripts/check-translations.cjs --report",
    "i18n:validate": "npm run i18n:scan && npm run validate:json && npm run i18n:check",
