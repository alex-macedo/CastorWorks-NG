    "averageDso": "DSO Promedio",
    "cashIn": "Entradas de Efectivo",
    "cashOut": "Salidas de Efectivo",
    "collectionRate": "Tasa de Cobro",
    "days": "días",
    "definitions": {
      "averageDso": {
        "formula": "Promedio de días entre emisión y pago",
        "source": "financial_ar_invoices (facturas pagadas)"
      },
      "cashIn": {
        "formula": "Suma de transacciones de ingreso",
        "source": "project_financial_entries (entry_type = income)"
      },
      "cashOut": {
        "formula": "Suma de transacciones de gasto",
        "source": "project_financial_entries (entry_type = expense)"
      },
      "collectionRate": {
        "formula": "Monto Pagado / Monto Facturado Total * 100",
        "source": "financial_ar_invoices (issue_date en el período)"
      },
      "grossMargin": {
        "formula": "(Entradas de Efectivo - Salidas de Efectivo) / Entradas de Efectivo * 100",
        "source": "project_financial_entries"
      },
      "monthlyBurnRate": {
        "formula": "(Salidas de Efectivo / días del período) * 30",
        "source": "project_financial_entries (entry_type = expense)"
      },
      "netCashFlow": {
        "formula": "Entradas de Efectivo - Salidas de Efectivo",
        "source": "project_financial_entries"
      },
      "outstandingAr": {
        "formula": "Suma de (Monto Total - Monto Pagado)",
        "source": "financial_ar_invoices"
      }
    },
