# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and required for the app to run.
#
# Vite only loads env from the project root. Use VITE_ prefix for client exposure.
#
# IMPORTANT: URL and anon key must be from the SAME Supabase project.
# - Original CastorWorks (dev.castorworks.cloud → Kong 8000):
#   Copy VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY from the CastorWorks repo .env.local.
# - CastorWorks-NG (devng.castorworks.cloud → Kong 8003):
#   VITE_SUPABASE_URL=https://devng.castorworks.cloud
#   VITE_SUPABASE_ANON_KEY = value of ANON_KEY in docs/.env.supabase

VITE_SUPABASE_URL=https://devng.castorworks.cloud
VITE_SUPABASE_ANON_KEY=

# Optional: use this key name instead of VITE_SUPABASE_ANON_KEY if you prefer
# VITE_SUPABASE_PUBLISHABLE_KEY=
