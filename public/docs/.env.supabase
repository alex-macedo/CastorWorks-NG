############
# Auth
############
# Use the public NG URL so Auth redirects and API calls work when clients use https://devng.castorworks.cloud
SITE_URL=https://devng.castorworks.cloud
ADDITIONAL_REDIRECT_URLS=https://devng.castorworks.cloud,https://studiong.castorworks.cloud
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
API_EXTERNAL_URL=https://devng.castorworks.cloud

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_Hv4VdNTq_2JxXgfC3pWfyjP8ZhCAjPQWE
SMTP_SENDER_NAME=CastorWorks
ENABLE_ANONYMOUS_USERS=false

ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

############
# Studio
############

