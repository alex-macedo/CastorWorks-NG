        "subvalue": "Entradas projetadas menos saídas projetadas",
        "title": "Posição Líquida de Caixa (13s)"
      },
      "nfeReconciliation": {
        "formula": "NF-e vinculadas / total de NF-e, com valor pendente não vinculado",
        "source": "sefaz_nfe_records.link_status, sefaz_nfe_records.total_amount",
        "subvalue": "{{pending}} pendente • {{total}} NF-e",
        "title": "Gap de Conciliação NF-e"
      },
      "noDataYet": "Sem dados ainda",
      "overdueAr": {
        "formula": "Soma de max(0, total_amount - amount_paid) dos recebíveis vencidos",
        "source": "financial_ar_invoices.total_amount, amount_paid, status, days_overdue",
        "subvalue": "{{days}} dias de atraso médio • {{count}} faturas",
