    "hooks:install": "node scripts/install-git-hooks.js",
    "build": "npm run copy-docs && vite build",
    "copy-docs": "mkdir -p public/docs && rsync -av --exclude='.DS_Store' docs/ public/docs/",
    "clean": "rm -rf dist node_modules/.vite",
    "build:clean": "npm run clean && npm run build",
    "build:dev": "npm run copy-docs && vite build --mode development",
    "lint": "eslint .",
    "lint:hooks": "eslint -c eslint.config.js 'src/**/*.{ts,tsx}'",
    "preview": "vite preview",
