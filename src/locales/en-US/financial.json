    "kpi": {
      "bdiDeviation": {
        "formula": "Realized BDI percentage - planned BDI percentage",
        "source": "projects, project_budget_items, app_settings (BDI configuration)",
        "subvalue": "Realized {{realized}}% vs planned {{planned}}%",
        "title": "Realized BDI vs Planned BDI"
      },
      "liquidityFloor": {
        "formula": "Minimum projected balance across the 13-week horizon",
        "source": "financial_cashflow_snapshots.projected_balance",
        "subvalue": "Lowest point in week {{week}}",
        "title": "Liquidity Floor (13w)"
      },
      "net13w": {
        "formula": "Total projected inflow - total projected outflow",
        "source": "financial_cashflow_snapshots.projected_inflow, projected_outflow",
        "subvalue": "Projected inflow minus projected outflow",
        "title": "Net Cash Position (13w)"
      },
      "nfeReconciliation": {
        "formula": "Linked NF-e / total NF-e, with pending unlinked amount",
        "source": "sefaz_nfe_records.link_status, sefaz_nfe_records.total_amount",
        "subvalue": "{{pending}} pending • {{total}} NF-e",
        "title": "NF-e Reconciliation Gap"
      },
      "noDataYet": "No data yet",
      "overdueAr": {
        "formula": "Sum of max(0, total_amount - amount_paid) for overdue receivables",
        "source": "financial_ar_invoices.total_amount, amount_paid, status, days_overdue",
        "subvalue": "{{days}} days avg delay • {{count}} invoices",
        "subvalue_many": "{{days}} days avg delay • {{count}} invoices",
        "subvalue_one": "{{days}} day avg delay • {{count}} invoice",
        "subvalue_other": "{{days}} days avg delay • {{count}} invoices",
        "title": "Overdue Receivables Exposure"
      },
      "taxExposure": {
        "formula": "Sum of latest INSS + ISS estimate per tax project",
        "source": "tax_estimates.inss_estimate, tax_estimates.iss_estimate",
        "subvalue": "{{count}} latest tax estimate(s)",
        "subvalue_many": "{{count}} latest tax estimates",
        "subvalue_one": "{{count}} latest tax estimate",
        "subvalue_other": "{{count}} latest tax estimates",
        "title": "Tax Exposure (INSS + ISS)"
      },
