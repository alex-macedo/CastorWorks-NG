{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "1.56.14",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"npm run dev\" \"npm run translation-api\" --names \"vite,api\" --prefix-colors \"cyan,green\"",
    "translation-api": "node scripts/translation-api.js",
