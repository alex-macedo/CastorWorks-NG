  "kpi": {
    "averageDso": "Average DSO",
    "cashIn": "Cash In",
    "cashOut": "Cash Out",
    "collectionRate": "Collection Rate",
    "days": "days",
    "definitions": {
      "averageDso": {
        "formula": "Average days from issue date to paid date",
        "source": "financial_ar_invoices (paid invoices)"
      },
      "cashIn": {
        "formula": "Sum of income entries",
        "source": "project_financial_entries (entry_type = income)"
      },
      "cashOut": {
        "formula": "Sum of expense entries",
        "source": "project_financial_entries (entry_type = expense)"
      },
      "collectionRate": {
        "formula": "Amount Paid / Total Invoiced * 100",
        "source": "financial_ar_invoices (issue_date in period)"
      },
      "grossMargin": {
        "formula": "(Cash In - Cash Out) / Cash In * 100",
        "source": "project_financial_entries"
      },
      "monthlyBurnRate": {
        "formula": "(Cash Out / period days) * 30",
        "source": "project_financial_entries (entry_type = expense)"
      },
      "netCashFlow": {
        "formula": "Cash In - Cash Out",
        "source": "project_financial_entries"
      },
      "outstandingAr": {
        "formula": "Sum of (Total Amount - Amount Paid)",
        "source": "financial_ar_invoices"
      }
    },
