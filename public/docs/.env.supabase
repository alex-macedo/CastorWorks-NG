############
# Secrets
############

POSTGRES_PASSWORD=<REDACTED>
JWT_SECRET=<REDACTED>
ANON_KEY=<REDACTED>
SERVICE_ROLE_KEY=<REDACTED>

DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=<REDACTED>

SECRET_KEY_BASE=<REDACTED>
VAULT_ENC_KEY=<REDACTED>
PG_META_CRYPTO_KEY=<REDACTED>

############
# Database
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# Supavisor
############

POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=castorworks_ng
POOLER_DB_POOL_SIZE=5

############
# API / Kong
############

KONG_HTTP_PORT=8003
KONG_HTTPS_PORT=8447

############
# PostgREST
############

PGRST_DB_SCHEMAS=public,storage,graphql_public

############
# Auth
############
# Use the public NG URL so Auth redirects and API calls work when clients use https://devng.castorworks.cloud
SITE_URL=https://devng.castorworks.cloud
ADDITIONAL_REDIRECT_URLS=https://devng.castorworks.cloud,https://studiong.castorworks.cloud
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
API_EXTERNAL_URL=https://devng.castorworks.cloud

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=<REDACTED>
SMTP_SENDER_NAME=CastorWorks
ENABLE_ANONYMOUS_USERS=false

ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

############
# Studio
############

STUDIO_DEFAULT_ORGANIZATION=AMSoft AI
STUDIO_DEFAULT_PROJECT=CastorWorks-NG

SUPABASE_PUBLIC_URL=http://localhost:8003

IMGPROXY_ENABLE_WEBP_DETECTION=true

############
# Functions
############

FUNCTIONS_VERIFY_JWT=false
# Optional: internal Auth URL for create-user Edge Function (e.g. http://auth:9999).
# When set, signup calls Auth Admin API without going through Kong, avoiding 403 bad_jwt.
# AUTH_INTERNAL_URL=http://auth:9999

# Edge Function secrets (Deno.env). Same values as in project .env.local; see docs/runbooks/recover-secrets-and-email.md
RESEND_API_KEY=<REDACTED>
ANTHROPIC_API_KEY=<REDACTED>
OPENAI_API_KEY=<REDACTED>

# Phase 4: Stripe (payment & subscription). Required for stripe-webhook, create-checkout-session, create-billing-portal-session.
# Get from Stripe Dashboard → Developers → API keys (Secret key) and Webhooks (Signing secret).
STRIPE_SECRET_KEY=<REDACTED>
STRIPE_WEBHOOK_SECRET=<REDACTED>
# Public URL for redirects (Checkout success/cancel, Customer Portal return). Use NG frontend URL.
APP_URL=https://devng.castorworks.cloud

############
# Analytics / Logflare
############

LOGFLARE_PUBLIC_ACCESS_TOKEN=<REDACTED>
LOGFLARE_PRIVATE_ACCESS_TOKEN=<REDACTED>

############
# Vector / Docker socket
############

DOCKER_SOCKET_LOCATION=/var/run/docker.sock

############
# Storage
############

TENANT_ID=castorworks-ng
REGION=local
GLOBAL_S3_BUCKET=project-images
