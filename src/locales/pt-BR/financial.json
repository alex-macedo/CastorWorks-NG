  "kpi": {
    "averageDso": "DSO Médio",
    "cashIn": "Entradas de Caixa",
    "cashOut": "Saídas de Caixa",
    "collectionRate": "Taxa de Cobrança",
    "days": "dias",
    "definitions": {
      "averageDso": {
        "formula": "Média de dias entre emissão e pagamento",
        "source": "financial_ar_invoices (faturas pagas)"
      },
      "cashIn": {
        "formula": "Soma dos lançamentos de entrada",
        "source": "project_financial_entries (entry_type = income)"
      },
      "cashOut": {
        "formula": "Soma dos lançamentos de saída",
        "source": "project_financial_entries (entry_type = expense)"
      },
      "collectionRate": {
        "formula": "Valor Pago / Valor Faturado Total * 100",
        "source": "financial_ar_invoices (issue_date no período)"
      },
      "grossMargin": {
        "formula": "(Entradas de Caixa - Saídas de Caixa) / Entradas de Caixa * 100",
        "source": "project_financial_entries"
      },
      "monthlyBurnRate": {
        "formula": "(Saídas de Caixa / dias do período) * 30",
        "source": "project_financial_entries (entry_type = expense)"
      },
      "netCashFlow": {
        "formula": "Entradas de Caixa - Saídas de Caixa",
        "source": "project_financial_entries"
      },
      "outstandingAr": {
        "formula": "Soma de (Valor Total - Valor Pago)",
        "source": "financial_ar_invoices"
      }
    },
