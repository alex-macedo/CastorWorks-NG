        "formula": "Somme des écritures de dépenses",
        "source": "project_financial_entries (entry_type = expense)"
      },
      "collectionRate": {
        "formula": "Montant Payé / Montant Facturé Total * 100",
        "source": "financial_ar_invoices (issue_date dans la période)"
      },
      "grossMargin": {
        "formula": "(Entrées de Trésorerie - Sorties de Trésorerie) / Entrées de Trésorerie * 100",
        "source": "project_financial_entries"
      },
      "monthlyBurnRate": {
        "formula": "(Sorties de Trésorerie / jours de la période) * 30",
        "source": "project_financial_entries (entry_type = expense)"
      },
      "netCashFlow": {
        "formula": "Entrées de Trésorerie - Sorties de Trésorerie",
        "source": "project_financial_entries"
      },
